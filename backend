pipeline {
    agent any

    environment {
        PROJECT_NAME = 'journal-cbs-backend'
        GIT_REPO = 'https://code.neyduetewa.gov.bt/govtech/fy25_26/journal_cbs/backend.git'
        BRANCH_NAME = 'feature/ndi-integration'
        SCANNER_HOME = tool 'sonar-scanner'
        REPORT_DIR = "reports"
        SCA_IMAGE = 'ghcr.io/google/osv-scanner'
        OWASP_REPORT_NAME = "${PROJECT_NAME}-OWASP-Report-${env.BUILD_NUMBER}.html"
        TRIVY_REPORT_NAME = "${PROJECT_NAME}-Trivy-Report-${env.BUILD_NUMBER}.html"
        HARBOR_REGISTRY = 'hub.neyduetewa.gov.bt'
        IMAGE_NAME = "${HARBOR_REGISTRY}/journal/journal-cbs"  
        TARGET_URL = 'http://172.30.3.10:30886'  
        PORT = '8000'
        ZAP_IMAGE = 'ghcr.io/zaproxy/zaproxy:stable'
        FRONTEND_URL = 'http://172.30.10.21:3000'
        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {
        
        
        stage('Clone and Set Tag') {
            steps {
                script {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "${env.BRANCH_NAME}"]],  
                        userRemoteConfigs: [[
                            url: "${env.GIT_REPO}",
                            credentialsId: 'sandeep-gitlab-creds'
                        ]],
                        extensions: [[$class: 'CloneOption', noTags: false]]
                    ])
                    
                    env.IMAGE_TAG = "${BUILD_NUMBER}"
                    
                    echo "Using IMAGE_TAG: ${env.IMAGE_TAG}"
                    echo "Current directory: ${pwd()}"
                }
            }
        }
        
        stage('Static Code Analysis') {
            steps {
                withSonarQubeEnv('sonarqube-server') {
                    sh """
                        ${SCANNER_HOME}/bin/sonar-scanner \
                            -Dsonar.projectKey=${PROJECT_NAME} \
                            -Dsonar.projectName=${PROJECT_NAME} \
                            -Dsonar.projectVersion=${env.BUILD_NUMBER} \
                            -Dsonar.sources=. \
                            -Dsonar.python.coverage.reportPaths=coverage.xml \
                            -Dsonar.python.pylint.reportPath=pylint-report.txt \
                            -Dsonar.exclusions=**/migrations/**,**/__pycache__/**,**/venv/**,**/.git/**,**/tests/**,**/Dockerfile,**/compose.yaml,**/nginx.conf,**/*.md,poetry.lock,pyproject.toml \
                            -Dsonar.test.inclusions=**/tests/**,**/test_*.py \
                            -Dsonar.python.version=3.11
                    """
                }
            }
        }

        stage('OSV-Scanner SCA (Poetry)') {
            steps {
                script {
                    sh "mkdir -p ${REPORT_DIR}"
                    sh """
                        docker run --rm -v \$(pwd):/app \
                            ${SCA_IMAGE} \
                            --lockfile=/app/poetry.lock \
                            --format html > ${REPORT_DIR}/${OWASP_REPORT_NAME} || true
                    """
                    archiveArtifacts artifacts: "${REPORT_DIR}/${OWASP_REPORT_NAME}"
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                script {
                    sh 'mkdir -p reports'
                    
                    // OWASP Dependency Check with NVD API
                    dependencyCheck(
                        odcInstallation: 'Dependency-Check',
                        additionalArguments: """
                            --scan . \
                            --format HTML \
                            --format JSON \
                            --out reports/ \
                            --enableExperimental \
                            --nvdApiKey ${NVD_API_KEY} \
                            --nvdApiDelay 2000 \
                            --disableYarnAudit \
                            --data /var/lib/jenkins/owasp-data
                        """
                    )
                    
                    // Rename reports to include build number
                    sh """
                        mv reports/dependency-check-report.html reports/${PROJECT_NAME}-OWASP-DC-Report-${BUILD_NUMBER}.html || true
                        mv reports/dependency-check-report.json reports/${PROJECT_NAME}-OWASP-DC-Report-${BUILD_NUMBER}.json || true
                    """
                    
                    archiveArtifacts artifacts: "reports/${PROJECT_NAME}-OWASP-DC-Report-*"
                }
            }
        }
        
        stage('Safety Dependency Scan') {
            steps {
                script {
                    sh """
                        mkdir -p ${REPORT_DIR}
                        
                        docker run --rm -v \$(pwd):/app \
                            python:3.11-slim \
                            bash -c "cd /app && \
                                pip install poetry && \
                                poetry self add poetry-plugin-export && \
                                poetry export -f requirements.txt --output requirements.txt --without-hashes"
                        
                        docker run --rm -v \$(pwd):/target \
                            ghcr.io/pyupio/safety \
                            stage cicd scan --target /target/requirements.txt \
                            --output json > ${REPORT_DIR}/${PROJECT_NAME}-safety-report-${BUILD_NUMBER}.json || true
                        
                        rm -f requirements.txt
                    """
                    archiveArtifacts artifacts: "${REPORT_DIR}/${PROJECT_NAME}-safety-report-*"
                }
            }
        }

        stage('Build and Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'harbor-creds', 
                    passwordVariable: 'HARBOR_PASSWORD', 
                    usernameVariable: 'HARBOR_USERNAME'
                )]) {
                    script {
                        sh """
                            docker login ${HARBOR_REGISTRY} -u ${HARBOR_USERNAME} -p ${HARBOR_PASSWORD}
                            docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest --no-cache -f Dockerfile .

                        """
                    }
                }
            }
        }
        
        stage('Trivy Image Scan') {
            steps {
                script {
                    sh """
                        mkdir -p ${REPORT_DIR}
                        trivy image \
                            --db-repository public.ecr.aws/aquasecurity/trivy-db \
                            --java-db-repository public.ecr.aws/aquasecurity/trivy-java-db \
                            --scanners vuln \
                            --format template --template @/usr/local/share/trivy/templates/html.tpl \
                            --output ${REPORT_DIR}/${TRIVY_REPORT_NAME} \
                            --severity HIGH,CRITICAL \
                            --timeout 10m \
                            ${IMAGE_NAME}:${IMAGE_TAG} || true
                    """
                    archiveArtifacts artifacts: "${REPORT_DIR}/${TRIVY_REPORT_NAME}", allowEmptyArchive: true
                }
            }
        }


        stage('DAST Scan') {
            steps {
                script {
                    sh "sleep 30"
                    
                    sh """
                        mkdir -p ${REPORT_DIR}
                        chmod 777 ${REPORT_DIR}
                    """

                    def scanOutput = sh(script: """
                        docker run --rm \
                        --network host \
                        -v \$(pwd)/${REPORT_DIR}:/zap/wrk/:rw \
                        ${ZAP_IMAGE} \
                        zap-full-scan.py \
                        -t ${TARGET_URL} \
                        -r zap-report.html \
                        -x zap-report.xml \
                        -J zap-report.json \
                        -m 5 \
                        -z "-config connection.timeoutInSecs=30 -config api.disablekey=true" || true
                    """, returnStdout: true)

                    writeFile file: "${REPORT_DIR}/zap-scan-output.txt", text: scanOutput
                    archiveArtifacts artifacts: "${REPORT_DIR}/zap-report.*,${REPORT_DIR}/zap-scan-output.txt", fingerprint: true

                    if (fileExists("${REPORT_DIR}/zap-report.html")) {
                        echo "HTML report generated at ${REPORT_DIR}/zap-report.html"
                        if (scanOutput.contains('FAIL-NEW: 0')) {
                            echo 'No new security issues found'
                        } else {
                            unstable('Security vulnerabilities detected')
                        }
                    } else {
                        error("HTML report generation failed")
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'reports/*', fingerprint: true
            echo "Security reports archived successfully."
            
            script {
                sh """
                    docker-compose -f compose.yaml logs --tail=100 > ${REPORT_DIR}/container-logs.txt || true
                    docker-compose -f compose.yaml down || true
                    docker logout
                    docker rmi -f ${IMAGE_NAME}:${IMAGE_TAG} || true
                    docker rmi -f ${IMAGE_NAME}:latest || true
                    rm -f suppressions.xml
                """
            }
            
            cleanWs()
        }
        success {
            echo "Pipeline completed successfully for branch: ${BRANCH_NAME}"
            echo "Backend available at: ${TARGET_URL}"
        }
        failure {
            echo "Pipeline failed for branch: ${BRANCH_NAME}!"
            sh """
                docker-compose -f compose.yaml logs --tail=100 || true
                docker ps -a | grep journal || true
            """
        }
    }
}
